# ─────────────────────────────────────────────
# SimpCity Credentials (Option B — recommended)
# ─────────────────────────────────────────────
# The crawler logs in automatically using these credentials.
# It re-authenticates whenever the session expires — no manual cookie management needed.
SIMPCITY_USERNAME=your_simpcity_username
SIMPCITY_PASSWORD=your_simpcity_password

# ─────────────────────────────────────────────
# SimpCity Manual Cookie (Option A — fallback)
# ─────────────────────────────────────────────
# Only needed if you prefer to manage the cookie yourself.
# Get it from: DevTools → Application → Cookies → simpcity.cr → xf_session
# SIMPCITY_COOKIE=xf_session=YOUR_SESSION_VALUE_HERE

# ─────────────────────────────────────────────
# SimpCity Advanced (optional)
# ─────────────────────────────────────────────
# Override the base URL if the domain changes
# SIMPCITY_BASE_URL=https://simpcity.cr

# Custom user agent for crawl requests
# SIMPCITY_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ...

# ─────────────────────────────────────────────
# yt-dlp (optional)
# ─────────────────────────────────────────────
# Override path to yt-dlp binary if it's not in your system PATH
# YT_DLP_PATH=C:\Users\you\yt-dlp.exe

# ─────────────────────────────────────────────
# YouTube Data API v3 (optional)
# ─────────────────────────────────────────────
# Required to enable the YouTube source in the topbar.
# Get a key at: https://console.cloud.google.com/apis/credentials → Create API key
# Then enable the "YouTube Data API v3" library for your project.
# Free tier: 10,000 units/day (~100 searches).
# YOUTUBE_API_KEY=your_youtube_api_key

# ─────────────────────────────────────────────
# Reddit user-agent (used by all proxied Reddit calls)
# ─────────────────────────────────────────────
# REDDIT_USER_AGENT=NightfeedMediaViewer/1.0 (by your-username)

# ─────────────────────────────────────────────
# Booru API keys (optional)
# ─────────────────────────────────────────────
# Rule34 and Gelbooru both started requiring authenticated API access in 2024.
# Without these, those sources will show a "needs API key" error.
# Safebooru and e621 work without keys.
# Realbooru's API has been shut down by the site indefinitely.
#
# Rule34 — sign in at https://rule34.xxx → My Account → Options → API Access
# RULE34_API_KEY=
# RULE34_USER_ID=
#
# Gelbooru — sign in at https://gelbooru.com → My Account → Options → API Access
# GELBOORU_API_KEY=
# GELBOORU_USER_ID=
